# Copy to .env and fill in. Never commit .env.

# Postgres (Supabase) connection string for psycopg v3.
DATABASE_URL=

# Anthropic API key for the orchestrator + classification models.
ANTHROPIC_API_KEY=

# Gmail API OAuth client secrets + cached token paths.
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=

# Email mode: "demo" routes real sends to DEMO_SINK_EMAIL with a
# "[DEMO — Intended for: <real recipient>]" prefix. Use "live" for real sends.
EMAIL_MODE=demo

# Demo sink inbox that receives redirected outbound mail when EMAIL_MODE=demo.
DEMO_SINK_EMAIL=
